# ─────────────────────────────────────────────────────────────────
# HRMS Platform — Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
ENVIRONMENT=development
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# JWT secret from Supabase → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# ── AWS ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ── AI / LLM ─────────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Security ─────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── Google Calendar API (Schedule Interview feature) ─────────────
# Used by: POST /api/v1/interviews/generate-meet-link (HR Recruiter only)
#
# Step 1: Go to https://console.cloud.google.com
# Step 2: Create (or select) a project → Enable "Google Calendar API"
# Step 3: IAM & Admin → Service Accounts → Create Service Account
#         Grant it no project roles (it only needs calendar access)
# Step 4: Click the service account → Keys → Add Key → JSON
#         Download the JSON key file
# Step 5: Share your Google Calendar with the service account email
#         (Settings → Share with specific people → "Make changes to events")
# Step 6: Paste the FULL contents of the JSON key file below (as a single line)
#         OR set GOOGLE_SERVICE_ACCOUNT_FILE to its path on disk
#
# Option A — inline JSON string (recommended for deployments):
GOOGLE_SERVICE_ACCOUNT_JSON=
#
# Option B — path to the downloaded JSON key file (local dev):
GOOGLE_SERVICE_ACCOUNT_FILE=
#
# The Calendar ID to create events in.
# Use "primary" for the service account's own calendar, or paste the
# calendar ID of a shared calendar (found in Google Calendar settings).
GOOGLE_CALENDAR_ID=primary
